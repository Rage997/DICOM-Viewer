    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^4.1.10"
